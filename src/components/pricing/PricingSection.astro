---
/**
 * Pricing Section - Advisory Packages
 * Visualización de paquetes de 1, 3 y 5 sesiones
 */

const session1Url = "https://pay.hotmart.com/Q104268411L?off=daig1z7w"; // Existing one
const session3Url = "#"; // Placeholder for 3 sessions
const session5Url = "#"; // Placeholder for 5 sessions

const packages = [
  {
    name: "Sesión Individual",
    sessions: 1,
    price: 250,
    realValue: 250,
    discount: null,
    features: [
      "Diagnóstico financiero inicial",
      "Identificación de patrones de gasto",
      "Mapa de crecimiento base",
      "Sesión virtual via Google Meet",
      "Acompañamiento 360",
    ],
    cta: "Agendar 1 Sesión",
    url: session1Url,
    popular: false,
    color: "rebellion-green"
  },
  {
    name: "Trilogía de Crecimiento",
    sessions: 3,
    price: 675,
    realValue: 750,
    discount: "Ahorras $75 USD",
    features: [
      "Todo lo de la sesión individual",
      "Plan de acción a mediano plazo",
      "Seguimiento de avances",
      "Optimización de presupuesto",
      "Acceso prioritario",
    ],
    cta: "Obtener 3 Sesiones",
    url: session3Url,
    popular: true,
    color: "rebellion-cyan"
  },
  {
    name: "Acompañamiento Máximo",
    sessions: 5,
    price: 1100,
    realValue: 1250,
    discount: "Ahorras $150 USD",
    features: [
      "Todo lo de la trilogía",
      "Plan integral de inversión",
      "Acompañamiento extendido",
      "Revisión de metas anuales",
      "Soporte VIP vía WhatsApp",
    ],
    cta: "Obtener 5 Sesiones",
    url: session5Url,
    popular: false,
    color: "honey-beehive"
  }
];
---

<section id="pricing" class="relative py-20 lg:py-32 overflow-hidden bg-claudia-dark">
  <!-- Background Effects -->
  <div class="absolute inset-0 pointer-events-none">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[1000px] bg-claudia-accent-orange/5 rounded-full blur-[120px]"
    >
    </div>
  </div>

  <div class="container-rebellion relative z-10">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-20 px-4">
      <span
        class="inline-block px-4 py-2 rounded-full bg-claudia-accent-orange/10 text-claudia-accent-orange text-sm font-semibold mb-6 tracking-widest uppercase border border-claudia-accent-orange/20"
      >
        🌟 Tu Próximo Paso
      </span>
      <h2 class="text-4xl lg:text-6xl font-black text-white mb-6 leading-tight">
        Elige tu nivel de <span class="text-gradient-claudia">acompañamiento</span>
      </h2>
      <p class="text-xl text-claudia-text-gray font-light">
        De un diagnóstico rápido a una transformación financiera integral.
      </p>
    </div>

    <!-- Pricing Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto items-stretch px-4">
      {packages.map((pkg) => (
        <div class={`relative group flex flex-col ${pkg.popular ? 'scale-105 z-20' : 'z-10'}`}>
          {pkg.popular && (
            <div class="absolute -top-5 left-1/2 -translate-x-1/2 z-30">
              <span class="bg-gradient-to-r from-claudia-accent-orange to-orange-400 text-claudia-dark px-6 py-2 rounded-full font-black text-xs uppercase tracking-widest shadow-lg">
                Más Elegido
              </span>
            </div>
          )}

          <!-- Glow Effect -->
          <div
            class={`absolute -inset-1 bg-gradient-to-r from-${pkg.color} to-white/10 rounded-3xl blur-lg opacity-20 group-hover:opacity-40 transition duration-500`}
          >
          </div>

          <!-- Card -->
          <div
            class={`relative h-full glassmorphism rounded-3xl p-8 lg:p-10 border ${pkg.popular ? 'border-claudia-accent-orange/40 bg-white/[0.05]' : 'border-white/10 bg-white/[0.02]'} flex flex-col transition-all duration-500 group-hover:border-${pkg.color}/40`}
          >
            <!-- Header -->
            <div class="text-center mb-10">
              <h3 class="text-2xl font-bold text-white mb-2">{pkg.name}</h3>
              <div class="flex items-baseline justify-center gap-1">
                 <span class="text-4xl lg:text-5xl font-black text-white">${pkg.price}</span>
                 <span class="text-lg text-claudia-text-gray font-light uppercase tracking-tighter">USD</span>
              </div>
              {pkg.discount && (
                <div class="mt-2 text-claudia-accent-green font-bold text-sm uppercase tracking-widest bg-claudia-accent-green/10 inline-block px-3 py-1 rounded-full border border-claudia-accent-green/20">
                  {pkg.discount}
                </div>
              )}
              {pkg.realValue > pkg.price && (
                <p class="text-claudia-text-gray/50 line-through text-sm mt-2">
                  Valor Real: ${pkg.realValue} USD
                </p>
              )}
            </div>

            <!-- Features -->
            <ul class="space-y-4 mb-12 flex-grow">
              {pkg.features.map((feature) => (
                <li class="flex items-start gap-3">
                  <span class={`flex-shrink-0 w-5 h-5 rounded-full bg-white/10 flex items-center justify-center mt-0.5 text-claudia-accent-orange`}>
                    <svg
                      class="w-3 h-3"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="3"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                  </span>
                  <span class="text-claudia-text-gray text-sm leading-tight">{feature}</span>
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <a
              href={pkg.url}
              class={`w-full py-5 px-8 rounded-2xl font-black text-center uppercase tracking-widest transition-all duration-300 transform group-hover:-translate-y-1 ${
                pkg.popular 
                ? 'bg-claudia-accent-orange text-white shadow-[0_10px_30px_rgba(255,152,0,0.3)] hover:shadow-[0_15px_40px_rgba(255,152,0,0.4)]' 
                : 'bg-white/10 text-white hover:bg-white/20 border border-white/10'
              }`}
            >
              {pkg.cta}
            </a>
            
            <p class="text-[10px] text-center text-claudia-text-gray/40 mt-4 uppercase tracking-widest">
                Pago protegido vía Hotmart
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .text-gradient-claudia {
    background: linear-gradient(135deg, var(--color-claudia-accent-orange), var(--color-claudia-accent-green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
