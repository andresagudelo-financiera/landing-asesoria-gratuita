---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";

const name = Astro.url.searchParams.get("name") || "Consultor Autorizado";
const phone = Astro.url.searchParams.get("phone") || "";
const link = Astro.url.searchParams.get("link") || "#";
---

<MainLayout title="Número Verificado | Finanzas con Claudia Uribe">
    <main
        class="relative min-h-screen w-full flex flex-col items-center justify-center p-4 overflow-hidden"
    >
        <!-- Image de Fondo -->
        <div
            class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat"
            style="background-image: url('/descarga.jpeg');"
        >
            <!-- Overlay Verde - Usando RGBA para asegurar visibilidad -->
            <div
                class="absolute inset-0 backdrop-blur-[2px]"
                style="background-color: rgba(34, 197, 94, 0.7);"
            >
            </div>
        </div>

        <div
            class="relative z-10 w-full max-w-2xl bg-green-100 border-[4px] border-green-600 rounded-[2rem] p-10 md:p-14 shadow-[0_40px_100px_rgba(0,0,0,0.6)] flex flex-col items-center text-center animate-modal-entry"
        >
            <!-- Icon -->
            <div class="mb-8">
                <div
                    class="w-32 h-32 md:w-44 md:h-44 bg-green-600 rounded-full flex items-center justify-center border-[8px] border-white shadow-xl animate-icon-pop animate-pulse-subtle"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-20 w-20 md:h-28 md:w-28 text-white"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="4"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M5 13l4 4L19 7"></path>
                    </svg>
                </div>
            </div>

            <!-- Title -->
            <h1
                class="text-4xl md:text-7xl font-black text-[#1E3A8A] mb-2 tracking-tighter uppercase leading-none"
            >
                ¡NÚMERO VÁLIDO!
            </h1>

            <p class="text-xl md:text-3xl font-black text-[#1E3A8A] mb-8">
                Este número pertenece a:
            </p>

            <!-- Coach Info Box -->
            <div
                class="bg-white/80 backdrop-blur-sm rounded-3xl p-6 mb-8 border border-green-200 w-full shadow-inner"
            >
                <p
                    class="text-xs uppercase tracking-widest text-[#1E3A8A]/60 mb-1 font-black"
                >
                    Money Strategy Oficial
                </p>
                <p
                    class="text-3xl md:text-5xl font-black text-[#1E3A8A] mb-2 leading-tight uppercase italic"
                >
                    {name}
                </p>
                <p
                    class="text-lg font-mono text-gray-500 mb-6 bg-white/20 py-1 px-4 rounded-full border border-green-50/50 inline-block"
                >
                    {phone}
                </p>

                <a
                    href={link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center space-x-4 bg-[#25D466] hover:bg-[#1EBE55] text-white font-black py-5 px-10 rounded-2xl transition-all shadow-[0_10px_30px_rgba(37,212,102,0.4)] hover:scale-105 uppercase tracking-[0.1em] text-sm md:text-xl group"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-7 w-7 group-hover:scale-110 transition-transform"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"
                        ></path>
                    </svg>
                    <span>Contactar ahora</span>
                </a>
            </div>

            <p
                class="text-lg md:text-2xl font-black text-[#1E3A8A] leading-tight max-w-md"
            >
                Asegúrate de estar hablando con un <span class="text-green-600"
                    >Money Strategy</span
                > oficial del equipo de Claudia Uribe.
            </p>
        </div>

        <!-- Back Link -->
        <a
            href="/comprobador-de-numeros"
            class="relative z-10 mt-12 text-white hover:scale-105 font-black transition-all flex items-center gap-4 text-xl md:text-2xl uppercase tracking-[0.1em] drop-shadow-lg mb-20"
        >
            <span class="text-3xl">←</span> VOLVER A COMPROBAR
        </a>

        <!-- Footer Bar -->
        <footer class="absolute bottom-0 left-0 w-full bg-green-600 py-4 z-20">
            <p
                class="text-[10px] md:text-xs font-black text-white text-center uppercase tracking-[0.2em]"
            >
                TODOS LOS DERECHOS RESERVADOS – CLAUDIA URIBE
            </p>
        </footer>
    </main>
</MainLayout>

<style>
    .animate-icon-pop {
        animation: iconPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
    }

    .animate-pulse-subtle {
        animation: pulseSubtle 3s ease-in-out infinite 0.8s;
    }

    @keyframes modalEntry {
        from {
            opacity: 0;
            transform: scale(0.9) translateY(30px);
        }
        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    @keyframes iconPop {
        from {
            opacity: 0;
            transform: scale(0.5);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @keyframes pulseSubtle {
        0%,
        100% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.4);
        }
        50% {
            transform: scale(1.03);
            box-shadow: 0 0 20px 10px rgba(255, 255, 255, 0);
        }
    }
</style>
