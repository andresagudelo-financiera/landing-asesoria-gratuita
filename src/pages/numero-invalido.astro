---
import MainLayout from "../layouts/MainLayout.astro";

const phone = Astro.url.searchParams.get("phone") || "";
---

<script>
    // Track failed number verification
    if (typeof window !== "undefined" && "gtag" in window) {
        (window as any).gtag("event", "invalid_number_verification", {
            event_category: "validation",
            event_label: "phone_number_invalid",
        });
    }
</script>

<MainLayout title="Número Inválido ⚠️ | Finanzas con Claudia Uribe">
    <main
        class="min-h-screen bg-gradient-to-br from-red-50 via-white to-red-50 flex items-center justify-center p-4 relative overflow-hidden"
    >
        <!-- Image de Fondo -->
        <div
            class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat"
            style="background-image: url('/descarga.jpeg');"
        >
            <!-- Overlay Rojo - Usando RGBA para asegurar visibilidad -->
            <div
                class="absolute inset-0 backdrop-blur-[2px]"
                style="background-color: rgba(239, 68, 68, 0.7);"
            >
            </div>
        </div>

        <div
            class="relative z-10 w-full max-w-2xl bg-red-100 border-[4px] border-red-600 rounded-[2rem] p-10 md:p-14 shadow-[0_40px_100px_rgba(0,0,0,0.6)] flex flex-col items-center text-center animate-modal-entry"
        >
            <!-- Icon -->
            <div class="mb-8">
                <div
                    class="w-32 h-32 md:w-44 md:h-44 bg-red-600 rounded-full flex items-center justify-center border-[8px] border-white shadow-xl animate-icon-pop animate-pulse-subtle"
                >
                    <span
                        class="text-8xl md:text-[10rem] font-black text-white leading-none"
                        style="font-size: 5rem;">!</span
                    >
                </div>
            </div>

            <!-- Title -->
            <h1
                class="text-4xl md:text-7xl font-black text-[#1E3A8A] mb-8 tracking-tighter uppercase leading-none"
            >
                ¡NÚMERO NO VÁLIDO!
            </h1>

            <!-- Subtext -->
            <p
                class="text-xl md:text-3xl font-black text-[#1E3A8A] max-w-md leading-tight mb-8"
            >
                El número NO pertenece al equipo <span class="text-red-600"
                    >Money Strategy</span
                > de Claudia Uribe.
            </p>
        </div>

        <!-- Back Link -->
        <a
            href="/comprobador-de-numeros"
            class="relative z-10 mt-12 text-white hover:scale-105 font-black transition-all flex items-center gap-4 text-xl md:text-2xl uppercase tracking-[0.1em] drop-shadow-lg mb-20"
        >
            <span class="text-3xl">←</span> VOLVER A COMPROBAR
        </a>

        <!-- Footer Bar -->
        <footer class="absolute bottom-0 left-0 w-full bg-red-600 py-4 z-20">
            <p
                class="text-[10px] md:text-xs font-black text-white text-center uppercase tracking-[0.2em]"
            >
                TODOS LOS DERECHOS RESERVADOS – CLAUDIA URIBE
            </p>
        </footer>
    </main>
</MainLayout>

<style>
    .animate-icon-pop {
        animation: iconPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
    }

    .animate-pulse-subtle {
        animation: pulseSubtle 3s ease-in-out infinite 0.8s;
    }

    @keyframes modalEntry {
        from {
            opacity: 0;
            transform: scale(0.9) translateY(30px);
        }
        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    @keyframes iconPop {
        from {
            opacity: 0;
            transform: scale(0.5);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @keyframes pulseSubtle {
        0%,
        100% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.4);
        }
        50% {
            transform: scale(1.03);
            box-shadow: 0 0 20px 10px rgba(255, 255, 255, 0);
        }
    }
</style>
