---
import MainLayout from "../../layouts/MainLayout.astro";
import db from "../../utils/db";

// Query leads from the local database
const leads = db
    .prepare("SELECT * FROM investment_leads ORDER BY created_at DESC")
    .all() as any[];

const formatDate = (dateString: string) => {
    const date = new Date(dateString);
    return new Intl.DateTimeFormat("es-CO", {
        day: "2-digit",
        month: "short",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit",
    }).format(date);
};
---

<MainLayout title="Admin - Registros Calculadora Inversión">
    <main
        class="min-h-screen bg-gray-50 pt-24 pb-12 px-4 selection:bg-blue-100 selection:text-blue-900"
    >
        <div class="w-full max-w-6xl mx-auto flex flex-col gap-6">
            <div
                class="flex justify-between items-center bg-white p-6 rounded-2xl shadow-sm border border-gray-100"
            >
                <div>
                    <h1 class="text-2xl md:text-3xl font-bold text-gray-900">
                        Registros de Calculadora
                    </h1>
                    <p class="text-sm text-gray-500 mt-1">
                        Total de registros: {leads.length}
                    </p>
                </div>
            </div>

            <div
                class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden"
            >
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm whitespace-nowrap">
                        <thead
                            class="bg-gray-50 border-b border-gray-100 text-gray-700"
                        >
                            <tr>
                                <th
                                    scope="col"
                                    class="px-6 py-4 font-semibold rounded-tl-lg"
                                    >ID</th
                                >
                                <th scope="col" class="px-6 py-4 font-semibold"
                                    >Fecha</th
                                >
                                <th scope="col" class="px-6 py-4 font-semibold"
                                    >Nombre</th
                                >
                                <th scope="col" class="px-6 py-4 font-semibold"
                                    >Email</th
                                >
                                <th scope="col" class="px-6 py-4 font-semibold"
                                    >Perfil</th
                                >
                                <th scope="col" class="px-6 py-4 font-semibold"
                                    >Score</th
                                >
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 text-gray-600">
                            {
                                leads.length === 0 ? (
                                    <tr>
                                        <td
                                            colspan="6"
                                            class="px-6 py-8 text-center text-gray-500"
                                        >
                                            No hay registros disponibles
                                            todavía.
                                        </td>
                                    </tr>
                                ) : (
                                    leads.map((lead) => (
                                        <tr class="hover:bg-gray-50 transition-colors">
                                            <td class="px-6 py-4 text-gray-400">
                                                #{lead.id}
                                            </td>
                                            <td class="px-6 py-4">
                                                {formatDate(lead.created_at)}
                                            </td>
                                            <td class="px-6 py-4 font-medium text-gray-900">
                                                {lead.name}
                                            </td>
                                            <td class="px-6 py-4">
                                                {lead.email}
                                            </td>
                                            <td class="px-6 py-4">
                                                <span
                                                    class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                                                        lead.profile ===
                                                        "Arriesgado"
                                                            ? "bg-red-200 text-red-900 border border-red-300"
                                                            : lead.profile ===
                                                                "Agresivo"
                                                              ? "bg-red-100 text-red-800"
                                                              : lead.profile ===
                                                                  "Moderado"
                                                                ? "bg-orange-100 text-orange-800"
                                                                : lead.profile ===
                                                                    "Conservador"
                                                                  ? "bg-green-100 text-green-800"
                                                                  : "bg-blue-100 text-blue-800"
                                                    }`}
                                                >
                                                    {lead.profile}
                                                </span>
                                            </td>
                                            <td class="px-6 py-4">
                                                <div class="flex items-center gap-2">
                                                    <div class="w-full bg-gray-200 rounded-full h-1.5 max-w-[80px]">
                                                        <div
                                                            class="bg-blue-600 h-1.5 rounded-full"
                                                            style={`width: ${Math.min(100, Math.max(0, lead.score))}%`}
                                                        />
                                                    </div>
                                                    <span class="text-xs">
                                                        {lead.score}
                                                    </span>
                                                </div>
                                            </td>
                                        </tr>
                                    ))
                                )
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
</MainLayout>
